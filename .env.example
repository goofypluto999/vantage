# Vantage Environment Variables

# Copy this file to .env.local and fill in your values.
# Last full audit: 2026-05-12 — every name below is actually referenced
# in code (api/* or src/*). If you add a process.env.X reference,
# add it here too.

# ============================================================================
# SUPABASE (Required)
# ============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side (for Vercel API routes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# GEMINI AI (Required)
# ============================================================================
# Server-side key used by all api/* routes. Get one at:
#   https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Client-side fallback (only some legacy flows). Same value works.
# Most code paths use the server key — this is optional in practice.
VITE_GEMINI_API_KEY=your-gemini-api-key

# ============================================================================
# STRIPE (Required for payments)
# ============================================================================
# Get your keys from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — GBP (default currency)
# Two naming conventions are both accepted by the code; STRIPE_PRICE_*
# is canonical going forward, STRIPE_*_PRICE_ID kept for backward compat.
# Set EITHER pair; the canonical names win when both are set.
STRIPE_PRICE_STARTER=price_starter_gbp_xxx
STRIPE_PRICE_PRO=price_pro_gbp_xxx
STRIPE_PRICE_PREMIUM=price_premium_gbp_xxx

# Legacy aliases — still read by the code as a fallback when the
# canonical STRIPE_PRICE_* names above are unset. Leave blank if you've
# set the canonical names; the empty fallback is benign.
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# Stripe Price IDs — USD (required for US/$ checkout flow)
# Without these, USD users silently fall back to GBP pricing.
STRIPE_PRICE_STARTER_USD=price_starter_usd_xxx
STRIPE_PRICE_PRO_USD=price_pro_usd_xxx
STRIPE_PRICE_PREMIUM_USD=price_premium_usd_xxx

# ============================================================================
# AI JOB SEARCH (Required for /api/interview/jobsearch)
# ============================================================================
# Adzuna API — multi-country job listings (20+ countries supported).
# Register at: https://developer.adzuna.com/
# Without these, the job-search endpoint silently returns only the
# global-remote Remotive results.
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# Optional: '1' forces the mock-jobs adapter on, useful for local dev
# without burning real Adzuna quota. Leave blank in production.
JOBSEARCH_MOCK=

# ============================================================================
# DEPLOYMENT / ROUTING
# ============================================================================
# Canonical production hostname. Used for Stripe success_url / cancel_url
# and any other absolute-URL construction. WITHOUT this, the code falls
# back to VERCEL_URL (the .vercel.app preview URL), which means custom-
# domain users get redirected away from your real domain on checkout.
APP_URL=https://aimvantage.uk

# Vercel sets VERCEL_URL automatically — no need to add it here.
# NODE_ENV is set automatically by Vercel.

# ============================================================================
# ADMIN
# ============================================================================
# Comma-separated list of email addresses authorised to call /api/admin/*.
# Without this, every admin endpoint silently allows zero admins
# (safe but renders the admin dashboard unusable).
ADMIN_EMAILS=you@example.com,coworker@example.com

# ============================================================================
# FREE TOOL FLAGS (optional)
# ============================================================================
# '1' enables a soft rate-limit on /api/roast. Default: off (leave blank).
ROAST_RATELIMIT_ENABLED=

# '1' disables /api/roast entirely (returns 503). Useful for cost
# emergencies. Default: off (leave blank).
ROAST_DISABLED=

# ============================================================================
# GOOGLE OAuth (Optional)
# ============================================================================
# Set up in Supabase Dashboard → Authentication → Providers → Google.
# These are NOT read by Vantage code directly — Supabase consumes them.
# Including for ops reference only.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
