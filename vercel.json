{
  "functions": {
    "api/analyze/index.ts": { "maxDuration": 60 },
    "api/interview/[action].ts": { "maxDuration": 30 },
    "api/rewrite-tone/index.ts": { "maxDuration": 30 },
    "api/roast/index.ts": { "maxDuration": 20 },
    "api/decode-rejection/index.ts": { "maxDuration": 20 },
    "api/ghost-job-check/index.ts": { "maxDuration": 20 },
    "api/admin/[action].ts": { "maxDuration": 30 }
  },
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=(), interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
        { "key": "Link", "value": "<https://aimvantage.uk/api/webmention>; rel=\"webmention\"" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com https://www.clarity.ms https://*.clarity.ms https://c.bing.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co https://api.stripe.com https://r.jina.ai https://s.jina.ai https://www.clarity.ms https://*.clarity.ms https://c.bing.com; frame-src 'self' https://js.stripe.com https://hooks.stripe.com; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/sitemap(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600, s-maxage=600, must-revalidate" }
      ]
    },
    {
      "source": "/(rss|atom|feed)\\.(xml|json)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600, s-maxage=600, must-revalidate" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600, must-revalidate" }
      ]
    },
    {
      "source": "/llms(-full)?.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600, must-revalidate" }
      ]
    },
    {
      "source": "/(dashboard|account|admin|refer|reset-password)(/.*)?",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(?:js|mjs|css|woff|woff2|ttf|eot|otf|png|jpe?g|gif|svg|webp|avif|ico|map)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/credits", "destination": "/api/user?endpoint=credits" },
    { "source": "/api/analyses", "destination": "/api/user?endpoint=analyses" },
    {
      "source": "/((?!api/|assets/|frames/|blog/|markdown/|postman/|\\.env|\\.git/|\\.aws/|\\.ssh/|\\.htaccess|\\.htpasswd|\\.DS_Store|wp-admin|wp-includes|wp-login|wp-config|phpmyadmin|xmlrpc\\.php|vendor/|backup/|backups/|sql/|database/|db/|config\\.|setup\\.|install\\.|admin\\.).*)",
      "destination": "/"
    }
  ]
}
